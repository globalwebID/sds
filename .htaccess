# SDS modular compatibility routes
RewriteEngine On
RewriteRule ^absensi(?:/(.*))?$ modules/attendance/app/$1 [L,QSA]
RewriteRule ^anjungan(?:/(.*))?$ modules/kiosk/app/$1 [L,QSA]
RewriteRule ^mkantin(?:/(.*))?$ modules/canteen/app/$1 [L,QSA]
RewriteRule ^emoney(?:/(.*))?$ modules/emoney/app/$1 [L,QSA]
RewriteRule ^perpustakaan(?:/(.*))?$ modules/library/app/$1 [L,QSA]
RewriteRule ^(formulir|form|upload|proses_map|ambil_field_aktif|cetak_daftar_ulang|cetak_dokumen_daftar_ulang|instructions|progress)(?:\.php)?/?$ modules/enrollment/app/$1.php [L,QSA]

DirectoryIndex index.php
Options -Indexes -MultiViews

RewriteEngine On

# URL tanpa ekstensi: /formulir -> /formulir.php.
# REQUEST_FILENAME membuat aturan ini tetap portable pada localhost,
# subfolder hosting, maupun document root tanpa RewriteBase hardcoded.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]

# Jangan layani file konfigurasi, dump, log, dan artefak internal.
<FilesMatch "(^\.env|composer\.(json|lock)$|\.(sql|log|ini|lock|state\.json|bak|backup|zip|tar|gz|7z)$)">
    Require all denied
</FilesMatch>

# Arsip/salinan endpoint lama tidak boleh dieksekusi melalui web.
<FilesMatch "^(000-|--).+\.php$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header always unset X-Powered-By
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-Frame-Options "SAMEORIGIN"

    <FilesMatch "\.(?:css|js|png|jpe?g|gif|webp|svg|ico|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 7 days"
    ExpiresByType image/jpeg "access plus 7 days"
    ExpiresByType image/webp "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 7 days"
    ExpiresByType font/woff2 "access plus 30 days"
</IfModule>
