RewriteEngine On

# ===============================
# BLOK DIRECTORY LISTING
# ===============================
Options -Indexes

# ===============================
# BLOK AKSES FILE SENSITIF (DIRECT ACCESS SAJA)
# ===============================
<Files "_config.php">
  Require all denied
</Files>

<FilesMatch "\.(env|git|htaccess)">
  Require all denied
</FilesMatch>

# ===============================
# SECURITY HEADER
# ===============================
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# HTTPS sebaiknya dipaksa oleh konfigurasi hosting/reverse proxy.
# Installer juga mendukung localhost HTTP.

# ===============================
# CACHE OFF (SESSION SAFE)
# ===============================
<IfModule mod_headers.c>
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
</IfModule>
